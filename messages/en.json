        "About": {
            "title": "About Us",
            "aboutItems": {
                "Star": {
                    "title": "🎯Our Mission",
                    "description": "We share economic knowledge and aim to inspire young people with a passion for career-oriented professional development in business. We open doors to personal and professional success, creating a business culture."
                },
                "Book": {
                    "title": "🎯Our Mission",
                    "description": "The training we offer builds upon the state educational standards in general education, professional, sectoral, and specific training. We create motivations for learning, skills to cope with difficult academic and life situations, and form competencies and build relationships for collaboration among the trainees."
                },
                "Graduation": {
                    "title": "🌟Our Vision",
                    "description": "We conduct language training according to the levels of the European Framework of Reference for Languages. We organize professional practice in banking branches and schools, and internships in financial enterprises in real environments. We regularly introduce our students to people who have succeeded in becoming successful business leaders."
                },
                "Backpack": {
                    "title": "🌟Our Vision",
                    "description": "Events are organized using the 'experience' method and we work with students on various European projects related to economics, ecology, and social issues. We visit cultural institutions such as museums, theaters, and operas monthly, and introduce our future young professionals to prominent artists."
                }
            }
        },
        "Select": {
            "title": "Why Choose Us?",
            "selectReasons": {
                "Global": {
                    "title": "Global Opportunities:",
                    "description": "By organizing internships abroad, we fulfill dreams of working in chosen professions. Moreover, we provide an opportunity to gain work experience at a European level. Furthermore, we teach students to be responsible, open, and conscientious and give them a chance to make new international acquaintances and to learn about other cultures."
                },
                "Individual": {
                    "title": "Individual Approach to Learning:",
                    "description": "We want our students to improve their professional, linguistic, and social competencies. To facilitate this, we ensure that the training is conducted in small classes and adapt our methods to suit the individual needs of the students."
                },
                "Preperation": {
                    "title": "Preparation for Business Success:",
                    "description": "We share economic knowledge and inspire with a passion for career-oriented professional development for business realization. We build upon standards in general educational preparation and teach knowledge and skills to cope with difficult academic and life situations."
                }
            }
        },
